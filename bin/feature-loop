#!/usr/bin/env bash
#
# feature-loop — config-driven autonomous build → verify → fix loop.
#
# Project-agnostic. Reads ./.featureloop from the target repo for the bits that
# differ per project (gate command, base branch, prompts). The loop itself never
# changes. Run /spec and /plan first; this starts from the plan file.
#
#   1. worktree off origin/<base> on feature/<TICKET>-<slug>
#   2. /build         (the ONLY writer) ← plan + tasks/failures/*.md
#   3-5. parallel READ-ONLY gates: /test, project gates ($FL_GATES), security audit
#   6. loop fixes through /build until green, then /code-simplify + re-verify
#
# State → <worktree>/tasks/STATUS.md. Runs each `claude -p` with
# --dangerously-skip-permissions, so use it inside a container (see feature-loop-docker).
#
# Usage: feature-loop <TICKET> <slug>
set -euo pipefail

readonly FL_VERSION="0.4.0"
# Conservative identifier — TICKET/SLUG end up in branch names, paths, image tags,
# and the shell command that enters the container.
readonly IDENT_RE='^[A-Za-z0-9._-]{1,64}$'

die() {
  echo "ERROR: $*" >&2
  exit 2
}
validate_ident() { [[ "$2" =~ $IDENT_RE ]] || die "$1 must match $IDENT_RE"; }

usage() {
  cat >&2 << 'EOF'
Usage: feature-loop <TICKET> <slug>

Autonomous build → verify → fix loop for the current repo. Reads ./.featureloop
for project config (gate command, base branch, prompts). Run /spec and /plan first.

Options:
  -h, --help     show this help and exit
  -V, --version  print version and exit
EOF
}

NO_CONFIG=0
ARGS=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    -V | --version)
      echo "feature-loop ${FL_VERSION}"
      exit 0
      ;;
    --no-config)
      NO_CONFIG=1
      shift
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage
      exit 2
      ;;
    *)
      ARGS+=("$1")
      shift
      ;;
  esac
done
set -- ${ARGS[@]+"${ARGS[@]}"}

TICKET="${1:-}"
SLUG="${2:-}"
[ -n "$TICKET" ] && [ -n "$SLUG" ] || {
  usage
  exit 2
}

validate_ident TICKET "$TICKET"
validate_ident SLUG "$SLUG"

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ---- defaults, then project config overrides them ----
FL_BASE_BRANCH="${FL_BASE_BRANCH:-main}"
FL_MAX_ITERS="${FL_MAX_ITERS:-5}"
FL_PLAN_FILE="${FL_PLAN_FILE:-tasks/plan.md}"
FL_GATES="${FL_GATES:-}"
FL_CLAUDE="${FL_CLAUDE:-claude}"
# Where this run's artefacts (status, logs, summary, retrospective) are archived so
# they survive worktree teardown. The docker runner bind-mounts the host's
# $HOME/.feature-loop into /home/fluser/.feature-loop so the archive lands on the host.
# Env wins over .featureloop here: the runner sets this via -e to pin the in-container
# path to the bind-mount target, and a .featureloop value would otherwise clobber it.
_FL_ARCHIVE_DIR_ENV="${FL_ARCHIVE_DIR-}"
FL_ARCHIVE_DIR="${FL_ARCHIVE_DIR:-$HOME/.feature-loop}"
# Set FL_RETROSPECTIVE=0 to skip the post-run Claude reflection (saves one API call).
FL_RETROSPECTIVE="${FL_RETROSPECTIVE:-1}"
# shellcheck disable=SC1091
[ "$NO_CONFIG" -eq 0 ] && [ -f "$REPO_ROOT/.featureloop" ] && . "$REPO_ROOT/.featureloop"
[ -n "$_FL_ARCHIVE_DIR_ENV" ] && FL_ARCHIVE_DIR="$_FL_ARCHIVE_DIR_ENV"

[ -n "$FL_GATES" ] || {
  echo "ERROR: FL_GATES is empty. Create $REPO_ROOT/.featureloop (see docs/featureloop-config.md)." >&2
  exit 1
}
[ -f "$REPO_ROOT/$FL_PLAN_FILE" ] || {
  echo "ERROR: $FL_PLAN_FILE not found in repo. Run /plan first." >&2
  exit 1
}

FL_BUILD_PROMPT="${FL_BUILD_PROMPT:-Use the agent-skills incremental-implementation skill to work through the pending tasks in tasks/plan.md, implementing each incrementally with tests, and commit per task on the current git branch. Do NOT push. Do NOT edit anything under tasks/.}"
FL_TEST_PROMPT="${FL_TEST_PROMPT:-Use the agent-skills test-driven-development skill to review whether the changes on this branch are adequately tested against tasks/plan.md. READ-ONLY: do not modify files. If tests fail or coverage is inadequate, write tasks/failures/test.md (file:line + the fix needed); otherwise create nothing.}"
FL_SECURITY_PROMPT="${FL_SECURITY_PROMPT:-Use the agent-skills security-and-hardening skill to audit the changes on this branch. READ-ONLY: do not modify files. Write findings to tasks/failures/security.md (severity + file:line), or nothing if clean.}"
FL_SIMPLIFY_PROMPT="${FL_SIMPLIFY_PROMPT:-Use the agent-skills code-simplification skill to simplify the changes on this branch without changing behavior. Run tests after each change and revert any that break. Do NOT edit anything under tasks/.}"
FL_RETROSPECTIVE_PROMPT="${FL_RETROSPECTIVE_PROMPT:-Read tasks/STATUS.md and every file under tasks/logs/ and tasks/failures/. Write a concise retrospective to tasks/retrospective.md with three sections: ## What went well / ## What needed fixing (and what worked) / ## What should improve next run. Bullet points, no preamble.}"

GIT_COMMON_DIR="$(cd "$REPO_ROOT" && git rev-parse --git-common-dir)"
case "$GIT_COMMON_DIR" in /*) : ;; *) GIT_COMMON_DIR="$REPO_ROOT/$GIT_COMMON_DIR" ;; esac
WT_DIR="${FL_WT_DIR:-$REPO_ROOT/.worktrees/$TICKET}"
BRANCH="feature/${TICKET}-${SLUG}"
FLAGS=(--dangerously-skip-permissions)

# Run identity + timing — set before the EXIT trap so the archive captures everything,
# even an unexpected early exit.
RUN_ID="${TICKET}-$(date -u +%Y%m%dT%H%M%SZ)"
RUN_START_EPOCH="$(date +%s)"
RUN_STARTED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
OUTCOME="unknown"

# Never let the worktree dir or runtime artifacts get committed (shared across worktrees).
EXCLUDE="$GIT_COMMON_DIR/info/exclude"
mkdir -p "$(dirname "$EXCLUDE")"
touch "$EXCLUDE"
grep -qxF '.worktrees/' "$EXCLUDE" || echo '.worktrees/' >> "$EXCLUDE"
grep -qxF 'tasks/' "$EXCLUDE" || echo 'tasks/' >> "$EXCLUDE"

git -C "$REPO_ROOT" fetch origin "$FL_BASE_BRANCH"
[ -d "$WT_DIR" ] || git -C "$REPO_ROOT" worktree add -b "$BRANCH" "$WT_DIR" "origin/$FL_BASE_BRANCH"
cd "$WT_DIR"
mkdir -p tasks/logs tasks/failures
cp "$REPO_ROOT/$FL_PLAN_FILE" tasks/plan.md
[ -f "$REPO_ROOT/tasks/todo.md" ] && cp "$REPO_ROOT/tasks/todo.md" tasks/todo.md || true
[ -f "$REPO_ROOT/SPEC.md" ] && cp "$REPO_ROOT/SPEC.md" SPEC.md || true

# ---- status board ----
ST_WT="pending"
ST_BUILD="pending"
ST_TEST="pending"
ST_PIPE="pending"
ST_SEC="pending"
ST_SIMP="pending"
ITER=0

# ---- terminal output: TTY-gated color + headers (spinner/panel added below) ----
# Everything here collapses to a no-op off-TTY, so piped/headless output and
# tasks/logs/* stay byte-for-byte plain (no \033, no \r). `[ -t 1 ]` is the gate:
# feature-loop-docker only allocates a container TTY when attached, so this is
# exactly the right signal (see docs/featureloop-config.md).
#
# Color (NO_COLOR) and animation (FL_NO_SPINNER) are independent opt-outs, so they
# are derived separately from the raw TTY check rather than folded into one flag.
if [ -t 1 ]; then FL_TTY=1; else FL_TTY=0; fi

# SGR color — literal codes on a TTY unless NO_COLOR is set (https://no-color.org).
C_BLUE="" C_GREEN="" C_RED="" C_BOLD="" C_RESET=""
if [ "$FL_TTY" -eq 1 ] && [ -z "${NO_COLOR:-}" ]; then
  # shellcheck disable=SC2034  # C_GREEN is part of the palette, consumed by spin/_gate_panel below.
  C_BLUE=$'\033[34m' C_GREEN=$'\033[32m' C_RED=$'\033[31m'
  C_BOLD=$'\033[1m' C_RESET=$'\033[0m'
fi
# DECTCEM show-cursor (not color, so gated only on the TTY). Empty off-TTY.
C_CURSOR_SHOW=""
[ "$FL_TTY" -eq 1 ] && C_CURSOR_SHOW=$'\033[?25h'

# A blue `==>` (colored, not bold) followed by a bold title — Homebrew's headline.
hdr() { printf '%s==>%s %s%s%s\n' "$C_BLUE" "$C_RESET" "$C_BOLD" "$*" "$C_RESET"; }
# Warnings/errors carry a labelled prefix and go to stderr.
warn() { printf '%sWarning:%s %s\n' "$C_BOLD" "$C_RESET" "$*" >&2; }
err() { printf '%sError:%s %s\n' "$C_RED" "$C_RESET" "$*" >&2; }

# Animation (spinner + live gate panel) needs a TTY and the FL_NO_SPINNER opt-out
# unset. NO_COLOR does not disable it — color and animation are independent opt-outs.
FL_ANIMATE=1
{ [ "$FL_TTY" -eq 0 ] || [ "${FL_NO_SPINNER:-0}" = 1 ]; } && FL_ANIMATE=0
# DECTCEM hide-cursor — only meaningful while animating; empty otherwise.
C_CURSOR_HIDE=""
[ "$FL_ANIMATE" -eq 1 ] && C_CURSOR_HIDE=$'\033[?25l'

# Status marks + spinner frames: single-cell ✓/✗ and Homebrew's exact braille frame
# sequence by default. FL_ASCII=1 swaps in ASCII for ambiguous-width (e.g. CJK) terminals.
MARK_OK="✓" MARK_FAIL="✗"
FL_FRAMES=(⠋ ⠙ ⠚ ⠞ ⠖ ⠦ ⠴ ⠲ ⠳ ⠓)
if [ "${FL_ASCII:-0}" = 1 ]; then
  MARK_OK="[OK]" MARK_FAIL="[XX]"
  FL_FRAMES=('|' '/' '-' '\\')
fi

# spin <msg> <log> -- <cmd...>
# Run <cmd...> with its output redirected to <log>, resolving to a single ✓/✗ line.
# Attached: animate the braille spinner next to <msg> at ~0.1s. Off-TTY (or under
# FL_NO_SPINNER): print one ==> header and run inline — no escape codes reach the
# log or stdout. spin's exit status is the command's.
spin() {
  local msg="$1" log="$2" rc=0
  shift 2
  [ "${1:-}" = "--" ] && shift
  if [ "$FL_ANIMATE" -eq 0 ]; then
    hdr "$msg"
    "$@" > "$log" 2>&1 || rc=$?
    return "$rc"
  fi
  "$@" > "$log" 2>&1 &
  local pid=$! i=0
  printf '%s' "$C_CURSOR_HIDE"
  while kill -0 "$pid" 2> /dev/null; do
    printf '\r  %s%s%s %s' "$C_BLUE" "${FL_FRAMES[i % ${#FL_FRAMES[@]}]}" "$C_RESET" "$msg"
    i=$((i + 1))
    sleep 0.1
  done
  wait "$pid" || rc=$?
  printf '\r\033[K' # carriage return + erase-in-line, then the resolved mark
  local color="$C_GREEN" mark="$MARK_OK"
  [ "$rc" -eq 0 ] || { color="$C_RED" mark="$MARK_FAIL"; }
  printf '  %s%s%s %s\n' "$color" "$mark" "$C_RESET" "$msg"
  printf '%s' "$C_CURSOR_SHOW"
  return "$rc"
}

# Gate keys map to their failure file (presence of the file = that gate failed)
# and to a one-line screen result mirroring the STATUS.md wording.
_gate_failfile() {
  case "$1" in
    test) printf 'tasks/failures/test.md' ;;
    project) printf 'tasks/failures/pipeline.md' ;;
    security) printf 'tasks/failures/security.md' ;;
  esac
}
_gate_result() {
  local ff
  ff="$(_gate_failfile "$1")"
  if [ -f "$ff" ]; then printf 'FAIL → %s' "${ff#tasks/}"; else printf 'pass'; fi
}

# Redraw the three gate lines once: a spinner frame + "running" while the PID is
# alive, or the resolved ✓/✗ verdict once it has exited. Each line erases to EOL.
# Args: <frame> <pid-test> <pid-project> <pid-security>.
_gate_draw() {
  local frame="$1"
  local pids=("$2" "$3" "$4")
  local names=(test project security)
  local k name ff
  for k in 0 1 2; do
    name="${names[k]}"
    if kill -0 "${pids[k]}" 2> /dev/null; then
      printf '  %s%s%s %-8s running\033[K\n' "$C_BLUE" "$frame" "$C_RESET" "$name"
    else
      ff="$(_gate_failfile "$name")"
      if [ -f "$ff" ]; then
        printf '  %s%s%s %-8s FAIL → %s\033[K\n' "$C_RED" "$MARK_FAIL" "$C_RESET" "$name" "${ff#tasks/}"
      else
        printf '  %s%s%s %-8s pass\033[K\n' "$C_GREEN" "$MARK_OK" "$C_RESET" "$name"
      fi
    fi
  done
}

# Live in-place display for the three concurrent gates (TTY only). Redraws the three
# lines via CUU/EL at ~0.1s until every PID exits; the final verdict persists. Never
# called when FL_ANIMATE=0 — run_gates prints plain result lines there instead.
_gate_panel() {
  local p_test="$1" p_pipe="$2" p_sec="$3" i=0
  printf '  %sGates%s\n' "$C_BOLD" "$C_RESET"
  printf '%s' "$C_CURSOR_HIDE"
  _gate_draw "${FL_FRAMES[0]}" "$p_test" "$p_pipe" "$p_sec"
  while kill -0 "$p_test" 2> /dev/null || kill -0 "$p_pipe" 2> /dev/null || kill -0 "$p_sec" 2> /dev/null; do
    sleep 0.1
    i=$(((i + 1) % ${#FL_FRAMES[@]}))
    printf '\033[3A' # cursor-up 3, back to the first gate line
    _gate_draw "${FL_FRAMES[i]}" "$p_test" "$p_pipe" "$p_sec"
  done
  printf '\033[3A' # final redraw, now that all three have resolved
  _gate_draw "${FL_FRAMES[i]}" "$p_test" "$p_pipe" "$p_sec"
  printf '%s' "$C_CURSOR_SHOW"
  wait "$p_test" "$p_pipe" "$p_sec" 2> /dev/null || true
}

render_status() {
  local open="none" f
  if ls tasks/failures/*.md > /dev/null 2>&1; then
    open=""
    for f in tasks/failures/*.md; do open="${open}$(basename "$f") "; done
  fi
  cat > tasks/STATUS.md << EOF
# ${TICKET} — feature-loop        iteration ${ITER} / ${FL_MAX_ITERS}

- branch:   \`${BRANCH}\`
- worktree: \`${WT_DIR}\`

| Phase              | State       |
|--------------------|-------------|
| Worktree           | ${ST_WT}    |
| Build (writer)     | ${ST_BUILD} |
| Test               | ${ST_TEST}  |
| Project gates      | ${ST_PIPE}  |
| Security hardening | ${ST_SEC}   |
| Code simplify      | ${ST_SIMP}  |

Open failures: ${open}

_updated $(date '+%Y-%m-%d %H:%M:%S')_
EOF
}
run_retrospective() {
  [ "$FL_RETROSPECTIVE" = "0" ] && return 0
  "$FL_CLAUDE" "${FLAGS[@]}" -p "$FL_RETROSPECTIVE_PROMPT" \
    > "tasks/logs/retrospective.log" 2>&1 || true
}

archive_run() {
  local outcome="${1:-unknown}"
  local end_epoch duration arc_dir idx
  end_epoch="$(date +%s)"
  duration=$((end_epoch - RUN_START_EPOCH))
  arc_dir="$FL_ARCHIVE_DIR/runs/$RUN_ID"
  mkdir -p "$arc_dir" 2> /dev/null || return 0

  # Carry the artefacts that survive worktree teardown.
  [ -f tasks/STATUS.md ] && cp tasks/STATUS.md "$arc_dir/" 2> /dev/null || true
  [ -f tasks/retrospective.md ] && cp tasks/retrospective.md "$arc_dir/" 2> /dev/null || true
  [ -d tasks/logs ] && cp -R tasks/logs "$arc_dir/" 2> /dev/null || true
  [ -d tasks/failures ] && cp -R tasks/failures "$arc_dir/" 2> /dev/null || true

  # Per-file diff stat so you see what changed without checking out the branch.
  git diff --stat "origin/$FL_BASE_BRANCH"..HEAD > "$arc_dir/diff.stat" 2> /dev/null || true

  # Machine-readable summary.
  cat > "$arc_dir/summary.json" << EOF
{
  "run_id":         "$RUN_ID",
  "ticket":         "$TICKET",
  "slug":           "$SLUG",
  "branch":         "$BRANCH",
  "base_branch":    "$FL_BASE_BRANCH",
  "outcome":        "$outcome",
  "iterations":     $ITER,
  "max_iterations": $FL_MAX_ITERS,
  "duration_sec":   $duration,
  "started_at":     "$RUN_STARTED_AT",
  "ended_at":       "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

  # Human-readable one-pager.
  {
    echo "# Run $RUN_ID"
    echo
    echo "- Ticket:      \`$TICKET\`"
    echo "- Slug:        \`$SLUG\`"
    echo "- Branch:      \`$BRANCH\`"
    echo "- Base branch: \`$FL_BASE_BRANCH\`"
    echo "- Outcome:     **$outcome**"
    echo "- Iterations:  $ITER / $FL_MAX_ITERS"
    echo "- Duration:    ${duration}s"
    echo "- Started:     $RUN_STARTED_AT"
    echo "- Ended:       $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo
    echo "See \`STATUS.md\`, \`retrospective.md\`, and \`logs/\` in this directory."
  } > "$arc_dir/summary.md"

  # Append a row to the cross-run INDEX.
  idx="$FL_ARCHIVE_DIR/INDEX.md"
  if [ ! -f "$idx" ]; then
    {
      echo "# feature-loop runs"
      echo
      echo "| Run ID | Outcome | Iter | Duration | Branch |"
      echo "|--------|---------|------|----------|--------|"
    } > "$idx"
  fi
  printf "| %s | %s | %s/%s | %ss | %s |\n" \
    "$RUN_ID" "$outcome" "$ITER" "$FL_MAX_ITERS" "$duration" "$BRANCH" >> "$idx"
}

on_exit() {
  # Restore the cursor in case an interrupted spinner left it hidden. Empty
  # off-TTY, so this is a no-op for piped/headless runs. Fires on EXIT and (via
  # the trap below) on INT/TERM.
  printf '%s' "$C_CURSOR_SHOW"
  render_status 2> /dev/null || true
  run_retrospective || true
  archive_run "${OUTCOME:-unknown}" || true
}
trap on_exit EXIT
# Route INT/TERM through a normal exit so the EXIT trap restores the cursor and
# archives the run before the interrupted process dies.
trap 'exit 130' INT
trap 'exit 143' TERM
ST_WT="ready"
render_status

run_build() {
  ST_BUILD="running"
  render_status
  local note=""
  if ls tasks/failures/*.md > /dev/null 2>&1; then
    note=" The previous iteration's gates failed — read EVERY file in tasks/failures/ and fix the root cause of each."
  fi
  spin "Build (writer) — iteration ${ITER}" "tasks/logs/build-${ITER}.log" -- \
    "$FL_CLAUDE" "${FLAGS[@]}" -p "${FL_BUILD_PROMPT}${note}" || true
  rm -f tasks/failures/*.md
  ST_BUILD="done (it.${ITER})"
  render_status
}

gate_test() { "$FL_CLAUDE" "${FLAGS[@]}" -p "$FL_TEST_PROMPT" > "tasks/logs/test-${ITER}.log" 2>&1 || true; }
gate_security() { "$FL_CLAUDE" "${FLAGS[@]}" -p "$FL_SECURITY_PROMPT" > "tasks/logs/security-${ITER}.log" 2>&1 || true; }

# Materialize the worktree (committed + tracked uncommitted changes) into a clean
# checkout that carries git's recorded file modes. On macOS, Docker Desktop's bind
# mount reports spurious +x bits that fail check-executables-have-shebangs; cloning
# onto the container's own filesystem restores the modes git actually tracks.
# core.fileMode=false keeps those bogus bits out of the diff we replay on top.
fl_materialize() {
  local dest="$1" patch
  git clone -q --no-hardlinks "$PWD" "$dest" || return 1
  patch="$(mktemp)"
  if git -c core.fileMode=false diff HEAD --binary > "$patch" && [ -s "$patch" ]; then
    git -C "$dest" apply --whitespace=nowarn "$patch" || {
      rm -f "$patch"
      return 1
    }
  fi
  rm -f "$patch"
}

# Run FL_GATES against a clean materialized checkout (correct modes), logging to $1.
# Returns the gate exit status; falls back to an in-place run if materialization fails.
gates_in_clean_tree() {
  local log="$1" rc=0 scratch
  scratch="$(mktemp -d)"
  if fl_materialize "$scratch/tree"; then
    (cd "$scratch/tree" && eval "$FL_GATES") > "$log" 2>&1 || rc=$?
  else
    {
      echo "WARN: clean-tree materialization failed; gating in place."
      eval "$FL_GATES"
    } > "$log" 2>&1 || rc=$?
  fi
  rm -rf "$scratch"
  return "$rc"
}

gate_pipeline() {
  local log="tasks/logs/gates-${ITER}.log" rc=0
  gates_in_clean_tree "$log" || rc=$?
  if [ "$rc" -ne 0 ]; then
    {
      echo "# Project gates failed (exit ${rc})"
      echo
      echo "Command: \`${FL_GATES}\`"
      echo
      echo '```'
      tail -n 80 "$log"
      echo '```'
    } > tasks/failures/pipeline.md
  fi
}

run_gates() {
  ST_TEST="running"
  ST_PIPE="running"
  ST_SEC="running"
  render_status
  gate_test &
  P1=$!
  gate_pipeline &
  P2=$!
  gate_security &
  P3=$!
  if [ "$FL_ANIMATE" -eq 1 ]; then
    _gate_panel "$P1" "$P2" "$P3"
  else
    hdr "Gates — test · project · security"
    wait "$P1" "$P2" "$P3" || true
    printf '    %-8s %s\n' test "$(_gate_result test)"
    printf '    %-8s %s\n' project "$(_gate_result project)"
    printf '    %-8s %s\n' security "$(_gate_result security)"
  fi
  [ -f tasks/failures/test.md ] && ST_TEST="FAIL -> failures/test.md" || ST_TEST="pass"
  [ -f tasks/failures/pipeline.md ] && ST_PIPE="FAIL -> failures/pipeline.md" || ST_PIPE="pass"
  [ -f tasks/failures/security.md ] && ST_SEC="FAIL -> failures/security.md" || ST_SEC="pass"
  render_status
}

# Commit the /code-simplify phase's tracked changes so the branch tip is shippable.
# FL_SIMPLIFY_PROMPT tells the agent NOT to commit and the build agent is the only
# other writer, so without this the green gate passes on tracked-but-uncommitted bytes
# and pushing the tip silently drops the cleanup (ISSUE-41). Engine-side so the commit
# is deterministic regardless of prompt overrides. Only tracked changes are staged —
# exactly what the post-simplify gate materialized via `git diff HEAD`. No-op when
# simplify changed nothing. A fallback identity is supplied only when none is configured.
fl_commit_simplify() {
  git diff --quiet HEAD -- && return 0
  git add -u
  # Fall back to a synthetic identity only when the repo has none configured
  # (e.g. CI / fresh clones). Passed as env vars, NOT a `git -c …` array:
  # expanding an empty array with "${arr[@]}" under `set -u` aborts on macOS's
  # stock Bash 3.2 — exactly the local-dev case this fix targets (ISSUE-41).
  if git config user.email > /dev/null 2>&1; then
    git commit -q -m "refactor(${TICKET}): apply /code-simplify cleanup"
  else
    GIT_AUTHOR_NAME=feature-loop GIT_AUTHOR_EMAIL=feature-loop@localhost \
      GIT_COMMITTER_NAME=feature-loop GIT_COMMITTER_EMAIL=feature-loop@localhost \
      git commit -q -m "refactor(${TICKET}): apply /code-simplify cleanup"
  fi
}

GREEN=0
for i in $(seq 1 "$FL_MAX_ITERS"); do
  ITER="$i"
  hdr "${TICKET} — feature-loop (iteration ${ITER}/${FL_MAX_ITERS})"
  run_build
  run_gates
  if ! ls tasks/failures/*.md > /dev/null 2>&1; then
    GREEN=1
    break
  fi
done

if [ "$GREEN" -ne 1 ]; then
  ST_SIMP="skipped (not green after ${FL_MAX_ITERS} iters)"
  render_status
  err "gates still failing after ${FL_MAX_ITERS} iterations. See tasks/failures/ and tasks/logs/."
  OUTCOME="not-green"
  exit 1
fi

ST_SIMP="running"
render_status
spin "Code simplify" "tasks/logs/simplify.log" -- \
  "$FL_CLAUDE" "${FLAGS[@]}" -p "$FL_SIMPLIFY_PROMPT" || true

if gates_in_clean_tree tasks/logs/gates-final.log; then
  fl_commit_simplify
  ST_SIMP="done"
  render_status
  # Final summary in a green header (the one place a non-blue header is used).
  printf '%s==>%s %s%s%s\n' "$C_GREEN" "$C_RESET" "$C_BOLD" \
    "DONE: ${BRANCH} is green. Review tasks/STATUS.md, then push and open the PR when ready." "$C_RESET"
  OUTCOME="green"
else
  ST_SIMP="broke gates -> tasks/logs/gates-final.log"
  render_status
  warn "code-simplify broke the gates. See tasks/logs/gates-final.log"
  OUTCOME="broke-simplify"
  exit 1
fi
